/* 闂傚倷绀佸﹢閬嶁€﹂崼銉嬪洭鎮界粙璺唶閻庤娲栧ú銊т焊?*/
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  transition: all 0.2s ease;
}

.btn-primary {
  background-color: #FF6B35;
  color: #fff;
}

.btn-primary:active {
  background-color: #E55A2E;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #666;
}

.btn-secondary:active {
  background-color: #e0e0e0;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #FF6B35;
  color: #FF6B35;
}

.btn-outline:active {
  background-color: #FFF4F0;
}

.btn-sm {
  padding: 15rpx 30rpx;
  font-size: 24rpx;
}

.btn-lg {
  padding: 25rpx 50rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 闂傚倷绀侀幉锟犮€冮幇顔筋潟闁哄洨鍠愬▍鐘绘煛瀹ュ骸浜為悘?*/
.card {
