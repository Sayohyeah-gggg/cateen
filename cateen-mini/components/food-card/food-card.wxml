<!-- components/food-card/food-card.wxml -->
<view class="food-card theme-{{theme}}" bind:tap="onCardTap">
  <view class="food-image-container">
    <image class="food-image" src="{{foodData.images[0]}}" mode="aspectFill" lazy-load="{{true}}" />
  </view>

  <view class="food-info">
    <text class="food-name">{{foodData.name}}</text>

    <view class="tag-row">
      <text class="chip chip-category">{{foodData.category}}</text>
      <block wx:for="{{foodData.tags || []}}" wx:key="*this">
        <text class="chip chip-tag">{{item}}</text>
      </block>
    </view>

    <view class="rating-section">
      <rating-star rating="{{foodData.avgRating || foodData.rating || 0}}" size="mini" />
      <text class="rating-text">{{foodData.avgRating || foodData.rating || 0}}</text>
      <text class="rating-dot">•</text>
      <text class="rating-count">{{foodData.ratingCount || 0}} 评</text>
    </view>
  </view>
</view>
