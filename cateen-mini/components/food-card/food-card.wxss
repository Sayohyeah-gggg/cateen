/* components/food-card/food-card.wxss - 美团风格两列布局 */
.food-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
  display: flex;
  flex-direction: column;
}

.food-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* 图片容器 - 两列布局优化 */
.food-image-container {
  position: relative;
  height: 220rpx;
  overflow: hidden;
  background: #F5F5F5;
}

.food-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 促销标签 - 美团风格 */
.promo-tag {
  position: absolute;
  top: 16rpx;
  left: 0;
  background: linear-gradient(90deg, #FF3B30 0%, #FF6B5A 100%);
  color: white;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx 8rpx 12rpx;
  border-radius: 0 20rpx 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 59, 48, 0.3);
}

/* 收藏按钮 - 美团风格，两列布局优化 */
.collect-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.collect-btn:active {
  transform: scale(0.9);
}

.collect-icon {
  font-size: 24rpx;
  color: #FFFFFF;
}

.collect-btn.collected .collect-icon {
  color: #FF3B30;
}

/* 美食信息 - 紧凑布局 */
.food-info {
  padding: 16rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.food-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  letter-spacing: -0.3rpx;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分类标签 - 紧凑样式 */
.food-category {
  font-size: 20rpx;
  color: #FF6600;
  background: rgba(255, 102, 0, 0.1);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  display: inline-block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

/* 标签组 */
.tags-row {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
}

.food-tag {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
}

.tag-category {
  color: #FF6600;
  background: rgba(255, 102, 0, 0.1);
  border: 1rpx solid rgba(255, 102, 0, 0.2);
}

.tag-new {
  color: #FF3B30;
  background: rgba(255, 59, 48, 0.1);
  border: 1rpx solid rgba(255, 59, 48, 0.2);
}

.tag-hot {
  color: #FFD100;
  background: rgba(255, 209, 0, 0.1);
  border: 1rpx solid rgba(255, 209, 0, 0.3);
}

/* 美食描述 - 隐藏以节省空间 */
.food-description {
  display: none;
}

.description-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 底部信息栏 - 美团风格 */
.food-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

/* 价格区域 */
.price-section {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.price-symbol {
  font-size: 24rpx;
  color: #FF3B30;
  font-weight: 600;
}

.price-value {
  font-size: 40rpx;
  color: #FF3B30;
  font-weight: 700;
  line-height: 1;
}

.original-price {
  font-size: 22rpx;
  color: #CCCCCC;
  text-decoration: line-through;
}

/* 评分和销量 - 紧凑布局 */
.rating-section {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: auto;
}

.rating-box {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.rating-star {
  font-size: 24rpx;
  color: #FFD100;
}

.rating-text {
  font-size: 22rpx;
  color: #FF6600;
  font-weight: 600;
}

.rating-count {
  font-size: 20rpx;
  color: #999999;
}

.sales-text {
  font-size: 22rpx;
  color: #999999;
}












