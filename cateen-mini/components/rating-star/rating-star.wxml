<!-- 星级评分组件 -->
<view class="rating-container">
  <view class="stars {{size}}">
    <view 
      class="star {{index < currentRating ? 'filled' : ''}}" 
      wx:for="{{5}}" 
      wx:key="index"
      bind:tap="onStarTap"
      data-index="{{index}}"
    >
      <text class="star-icon">★</text>
    </view>
  </view>
</view>

