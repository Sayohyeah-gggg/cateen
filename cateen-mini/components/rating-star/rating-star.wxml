<!-- components/rating-star/rating-star.wxml -->
<view class="rating-container">
  <view class="stars {{size}} {{editable ? 'editable' : ''}}">
    <view class="star {{index < currentRating ? 'filled' : ''}}" wx:for="{{5}}" wx:key="index" bind:tap="onStarTap" data-index="{{index}}">
      <text class="star-icon">*</text>
    </view>
  </view>
</view>
