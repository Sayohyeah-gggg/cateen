/* components/rating-star/rating-star.wxss */
.rating-container {
  display: inline-block;
}

.stars {
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.star {
  color: #ddd;
  transition: color 0.2s ease;
}

.star.filled {
  color: #FFD700;
}

.star-icon {
  display: block;
}

/* 婵犵數鍋為崹鍫曞箰閸濄儳鐭撻柟缁㈠枛缁犳牠鏌熼悙顒佹瀯闁绘帒锕弻娑樷攽閸℃浼岄梺?*/
.stars.mini .star-icon {
  font-size: 20rpx;
}

.stars.small .star-icon {
  font-size: 24rpx;
}

.stars.normal .star-icon {
  font-size: 28rpx;
}

.stars.large .star-icon {
  font-size: 36rpx;
}

/* 闂傚倷绀侀幉锟犳偡椤栫偛鍨傜€规洖娲﹂～鏇熴亜韫囨挻鍣虹紓宥呮喘閺岀喓鈧數顭堝瓭缂佹鍨垮?*/
.stars.editable .star {
  cursor: pointer;
}

.stars.editable .star:hover {
  color: #FFD700;
}











