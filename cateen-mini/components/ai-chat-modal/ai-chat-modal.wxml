<!-- components/ai-chat-modal/ai-chat-modal.wxml -->
<view class="chat-modal {{visible ? 'show' : 'hide'}}" wx:if="{{visible}}">
  <view class="modal-mask" bind:tap="closeChat"></view>

  <view class="chat-container">
    <view class="chat-header">
      <view class="header-left">
        <view class="avatar"><text class="avatar-icon">AI</text></view>
        <view class="header-info">
          <text class="assistant-name">{{title}}</text>
          <text class="status-text">在线</text>
        </view>
      </view>
      <view class="header-right">
        <view class="close-btn" bind:tap="closeChat"><text class="close-icon">x</text></view>
      </view>
    </view>

    <scroll-view class="message-list" scroll-y="{{true}}" scroll-into-view="{{scrollToBottom ? 'bottom' : ''}}" scroll-with-animation="{{true}}">
      <view class="message-item" wx:for="{{messages}}" wx:key="id">
        <view class="message user-message" wx:if="{{item.type === 'user'}}" bind:longpress="resendMessage" data-id="{{item.id}}">
          <view class="message-content">
            <text class="message-text">{{item.content}}</text>
            <text class="message-time">{{item.timestamp}}</text>
          </view>
          <view class="message-avatar"><text class="user-avatar">U</text></view>
        </view>

        <view class="message assistant-message" wx:if="{{item.type === 'assistant'}}" bind:longpress="onMessageLongPress" data-id="{{item.id}}">
          <view class="message-avatar"><text class="assistant-avatar">AI</text></view>
          <view class="message-content">
            <text class="message-text">{{item.content}}</text>
            <text class="message-time">{{item.timestamp}}</text>
          </view>
        </view>
      </view>

      <view class="typing-indicator" wx:if="{{isAiTyping}}">
        <view class="message-avatar"><text class="assistant-avatar">AI</text></view>
        <view class="typing-content">
          <view class="typing-dots"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
          <text class="typing-text">AI 输入中...</text>
        </view>
      </view>

      <view id="bottom" class="bottom-placeholder"></view>
    </scroll-view>

    <view class="input-area">
      <view class="input-container">
        <input class="message-input" placeholder="输入你的问题..." value="{{inputValue}}" bind:input="onInputChange" bind:confirm="sendMessage" disabled="{{isSending}}" />
        <view class="input-actions">
          <view class="clear-btn {{inputValue ? 'active' : ''}}" bind:tap="clearInput" wx:if="{{inputValue}}"><text class="clear-icon">x</text></view>
          <view class="send-btn {{inputValue && !isSending ? 'active' : ''}}" bind:tap="sendMessage"><text class="send-icon">发送</text></view>
        </view>
      </view>
    </view>
  </view>
</view>
