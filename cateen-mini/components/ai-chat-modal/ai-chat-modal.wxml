<!-- components/ai-chat-modal/ai-chat-modal.wxml -->
<view class="chat-modal {{visible ? 'show' : 'hide'}}" wx:if="{{visible}}">
  <!-- 遮罩层 -->
  <view class="modal-mask" bind:tap="closeChat"></view>
  
  <!-- 聊天框主体 -->
  <view class="chat-container">
    <!-- 聊天头部 -->
    <view class="chat-header">
      <view class="header-left">
        <view class="avatar">
          <text class="avatar-icon">🤖</text>
        </view>
        <view class="header-info">
          <text class="assistant-name">{{title}}</text>
          <text class="status-text">在线</text>
        </view>
      </view>
      <view class="header-right">
        <view class="close-btn" bind:tap="closeChat">
          <text class="close-icon">✕</text>
        </view>
      </view>
    </view>

    <!-- 消息列表 -->
    <scroll-view 
      class="message-list" 
      scroll-y="{{true}}"
      scroll-into-view="{{scrollToBottom ? 'bottom' : ''}}"
      scroll-with-animation="{{true}}"
    >
      <view class="message-item" wx:for="{{messages}}" wx:key="id">
        <!-- 用户消息 -->
        <view 
          class="message user-message" 
          wx:if="{{item.type === 'user'}}"
          bind:longpress="resendMessage"
          data-id="{{item.id}}"
        >
          <view class="message-content">
            <text class="message-text">{{item.content}}</text>
            <text class="message-time">{{item.timestamp}}</text>
          </view>
          <view class="message-avatar">
            <text class="user-avatar">👤</text>
          </view>
        </view>

        <!-- AI消息 -->
        <view 
          class="message assistant-message" 
          wx:if="{{item.type === 'assistant'}}"
          bind:longpress="onMessageLongPress"
          data-id="{{item.id}}"
        >
          <view class="message-avatar">
            <text class="assistant-avatar">🤖</text>
          </view>
          <view class="message-content">
            <text class="message-text">{{item.content}}</text>
            <text class="message-time">{{item.timestamp}}</text>
          </view>
        </view>
      </view>

      <!-- AI正在输入提示 -->
      <view class="typing-indicator" wx:if="{{isAiTyping}}">
        <view class="message-avatar">
          <text class="assistant-avatar">🤖</text>
        </view>
        <view class="typing-content">
          <view class="typing-dots">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
          <text class="typing-text">AI正在思考中...</text>
        </view>
      </view>

      <!-- 底部占位 -->
      <view id="bottom" class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="input-area">
      <view class="input-container">
        <input 
          class="message-input" 
          placeholder="请输入您的问题..."
          value="{{inputValue}}"
          bind:input="onInputChange"
          bind:confirm="sendMessage"
          disabled="{{isSending}}"
        />
        <view class="input-actions">
          <view 
            class="clear-btn {{inputValue ? 'active' : ''}}" 
            bind:tap="clearInput"
            wx:if="{{inputValue}}"
          >
            <text class="clear-icon">✕</text>
          </view>
          <view 
            class="send-btn {{inputValue && !isSending ? 'active' : ''}}" 
            bind:tap="sendMessage"
          >
            <text class="send-icon">发送</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>



