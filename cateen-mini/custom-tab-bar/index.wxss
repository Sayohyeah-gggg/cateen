/* custom-tab-bar/index.wxss */
.custom-tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: transparent;
  pointer-events: none;
}

.custom-tabbar {
  pointer-events: auto;
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.95);
  border-top: 1rpx solid rgba(148, 163, 184, 0.25);
  padding: 8rpx 8rpx calc(8rpx + env(safe-area-inset-bottom));
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
}

.custom-tabbar-wrap.theme-dark .custom-tabbar {
  background: rgba(15, 23, 42, 0.88);
  border-top-color: rgba(148, 163, 184, 0.28);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 6rpx 0;
}

.icon-holder {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid transparent;
  background: transparent;
}

.icon-holder.active {
  background: rgba(37, 99, 235, 0.1);
  border-color: rgba(37, 99, 235, 0.25);
}

.custom-tabbar-wrap.theme-dark .icon-holder.active {
  background: rgba(96, 165, 250, 0.18);
  border-color: rgba(96, 165, 250, 0.36);
}

.icon {
  width: 28rpx;
  height: 28rpx;
}

.label {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.1;
}

.custom-tabbar-wrap.theme-dark .label {
  color: #94a3b8;
}

.tab-item.active .label {
  color: #2563eb;
  font-weight: 600;
}

.custom-tabbar-wrap.theme-dark .tab-item.active .label {
  color: #60a5fa;
}
