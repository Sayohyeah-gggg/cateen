.ai-page {
  --space-4: 4rpx;
  --space-8: 8rpx;
  --space-12: 12rpx;
  --space-16: 16rpx;
  --space-24: 24rpx;
  --space-32: 32rpx;
  --space-40: 40rpx;
  --space-48: 48rpx;

  --radius-12: 12rpx;
  --radius-16: 16rpx;
  --radius-24: 24rpx;
  --radius-32: 32rpx;
}

.ai-page.theme-shell::before {
  background:
    radial-gradient(circle at 100% 0%, rgba(37, 99, 235, 0.14), transparent 36%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.06) 0%, rgba(15, 23, 42, 0) 52%);
}

.ai-page.theme-dark.theme-shell::before {
  background:
    radial-gradient(circle at 100% 0%, rgba(96, 165, 250, 0.2), transparent 38%),
    linear-gradient(180deg, rgba(2, 6, 23, 0.26) 0%, rgba(2, 6, 23, 0) 56%);
}

.page-scroll {
  height: 100vh;
}

.page-inner {
  padding:
    176rpx
    var(--space-24)
    calc(264rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.nav-tag {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 30rpx;
  height: 30rpx;
}

.welcome-panel {
  padding: var(--space-24);
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.welcome-title {
  font-size: var(--font-20);
  line-height: var(--line-20);
  color: var(--text-primary);
  font-weight: 700;
}

.welcome-desc {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-muted);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-12);
}

.quick-card {
  min-height: 120rpx;
  border-radius: var(--radius-24);
  border: 1rpx solid var(--border-soft);
  background: var(--bg-surface-strong);
  box-shadow: var(--shadow-sm);
  padding: var(--space-12);
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-12);
}

.quick-icon {
  font-size: 32rpx;
}

.quick-text {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.quick-title {
  font-size: 30rpx;
  line-height: 36rpx;
  color: var(--text-primary);
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quick-sub {
  font-size: 24rpx;
  line-height: 30rpx;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-16);
}

.chat-row {
  display: flex;
  align-items: flex-start;
  gap: var(--space-12);
}

.chat-row.user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 1rpx solid var(--border-soft);
  background: var(--bg-soft);
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.message-bubble {
  max-width: calc(100% - 56rpx);
  border-radius: var(--radius-24);
  border: 1rpx solid var(--border-soft);
  background: var(--bg-surface-strong);
  padding: var(--space-16);
  box-shadow: var(--shadow-sm);
}

.message-bubble.user {
  max-width: 66%;
  border-color: transparent;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
}

.message-text {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-primary);
  word-break: break-word;
  white-space: pre-wrap;
}

.message-bubble.user .message-text {
  color: #f8fafc;
}

.message-time {
  display: block;
  margin-top: var(--space-8);
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.message-bubble.user .message-time {
  color: rgba(248, 250, 252, 0.86);
}

.loading-line,
.typing {
  display: flex;
  align-items: center;
  gap: var(--space-8);
  padding-left: calc(var(--space-40) + var(--space-12));
}

.loading-text {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.dot,
.typing-dot {
  width: var(--space-8);
  height: var(--space-8);
  border-radius: 50%;
  background: var(--text-muted);
}

.dot {
  animation: pulse 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

.typing-dot {
  animation: floatDot 1s infinite ease-in-out;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes pulse {
  0%,
  80%,
  100% {
    opacity: 0.45;
    transform: scale(0.84);
  }

  40% {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes floatDot {
  0%,
  60%,
  100% {
    transform: translateY(0);
    opacity: 0.45;
  }

  30% {
    transform: translateY(-4rpx);
    opacity: 1;
  }
}

.input-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 120;
  padding: 0 var(--space-24);
}

.input-bar {
  border-radius: var(--radius-24);
  display: flex;
  align-items: center;
  gap: var(--space-12);
  padding: var(--space-12);
}

.message-input {
  flex: 1;
  min-height: 64rpx;
  border-radius: var(--radius-16);
  border: 1rpx solid var(--border-soft);
  background: var(--bg-soft);
  color: var(--text-primary);
  font-size: var(--font-14);
  line-height: var(--line-14);
  padding: 0 var(--space-16);
}

.send-button {
  margin: 0;
  width: 92rpx;
  height: 52rpx;
  border-radius: var(--radius-16);
  border: 1rpx solid var(--border-soft);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0) 48%),
    rgba(148, 163, 184, 0.26);
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.45),
    0 6rpx 14rpx rgba(15, 23, 42, 0.1);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  transition: transform var(--motion-fast) var(--ease-out), background var(--motion-fast) var(--ease-out), color var(--motion-fast) var(--ease-out);
}

.send-button.active {
  border-color: transparent;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0) 52%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.92) 0%, rgba(20, 184, 166, 0.84) 100%);
  color: #f8fafc;
}

.send-button.active:active {
  transform: translateY(var(--space-4));
}

.send-button::after {
  border: none;
}

.send-button[disabled] {
  background: var(--bg-soft);
  color: var(--text-muted);
}
