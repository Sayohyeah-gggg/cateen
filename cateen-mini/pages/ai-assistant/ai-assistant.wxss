/* pages/ai-assistant/ai-assistant.wxss */
/* 参考苹果UI设计风格 */

.ai-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F2F2F7; /* iOS浅灰背景 */
}

/* 聊天消息区域 */
.chat-messages {
  flex: 1;
  padding: 16rpx 32rpx;
  margin-top: 176rpx;
  margin-bottom: 100rpx;
}

/* 欢迎消息 */
.welcome-message {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.welcome-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.welcome-title {
  font-size: 34rpx;
  font-weight: 600; /* SF Pro字体风格 */
  color: #000000;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx; /* 苹果风格紧凑字距 */
}

.welcome-desc {
  font-size: 26rpx;
  color: #8E8E93; /* iOS灰色文字 */
  margin-bottom: 48rpx;
  font-weight: 400;
}

/* 快捷问题 - 苹果卡片风格 */
.quick-questions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  width: 100%;
}

.quick-item {
  background: #FFFFFF;
  border-radius: 16rpx; /* 苹果圆角 */
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04); /* 轻微阴影 */
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); /* 苹果动画曲线 */
  border: 0.5rpx solid rgba(0, 0, 0, 0.04);
}

.quick-item:active {
  transform: scale(0.96);
  background: #F9F9F9;
}

.quick-icon {
  font-size: 44rpx;
}

.quick-text {
  font-size: 24rpx;
  color: #3C3C43; /* iOS深灰文字 */
  font-weight: 500;
}

/* 消息列表 */
.message-list {
  padding-bottom: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 20rpx;
  animation: fadeIn 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-item.user {
  flex-direction: row-reverse;
}

.message-avatar {
  flex-shrink: 0;
  margin: 0 16rpx;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #E5E5EA;
}

.message-content {
  flex: 1;
  display: flex;
}

.message-item.user .message-content {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

.message-bubble.user {
  background: #007AFF; /* iOS蓝色 */
  color: white;
  border-bottom-right-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.15);
}

.message-bubble.assistant {
  background: #FFFFFF;
  color: #000000;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 0.5rpx solid rgba(0, 0, 0, 0.04);
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
  word-wrap: break-word;
  white-space: pre-wrap;
  font-weight: 400;
  letter-spacing: -0.3rpx;
}

.message-time {
  display: block;
  font-size: 20rpx;
  margin-top: 8rpx;
  opacity: 0.6;
  font-weight: 400;
}

/* 加载中提示 */
.loading-message {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.loading-dots {
  display: flex;
  gap: 6rpx;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #8E8E93;
  animation: dotPulse 1.4s infinite ease-in-out;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 400;
}

/* 打字中指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.typing-dots {
  display: flex;
  gap: 6rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border-radius: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  border: 0.5rpx solid rgba(0, 0, 0, 0.04);
}

.typing-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #8E8E93;
  animation: typingDotPulse 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) {
  animation-delay: 0s;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typingDotPulse {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-8rpx);
    opacity: 1;
  }
}

/* 输入区域 - iOS风格 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95); /* 毛玻璃效果背景 */
  backdrop-filter: blur(40rpx); /* iOS毛玻璃 */
  -webkit-backdrop-filter: blur(40rpx);
  padding: 12rpx 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
  border-top: 0.5rpx solid rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.message-input {
  flex: 1;
  background: #FFFFFF;
  border: 1rpx solid #E5E5EA;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #000000;
  transition: all 0.2s ease;
}

.message-input:focus {
  border-color: #007AFF;
  background: #FFFFFF;
}

.send-button {
  width: 68rpx;
  height: 68rpx;
  background: #007AFF;
  color: white;
  border: none;
  border-radius: 34rpx;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.2);
}

.send-button::after {
  border: none;
}

.send-button.active {
  background: #007AFF;
  transform: scale(1);
}

.send-button.active:active {
  transform: scale(0.92);
}

.send-button[disabled] {
  background: #E5E5EA;
  color: #8E8E93;
  box-shadow: none;
  opacity: 1;
}
