<!-- pages/ai-assistant/ai-assistant.wxml -->
<view class="ai-page theme-shell {{themeClass}}">
  <navigation-bar title="智能美食推荐助手" theme="{{theme}}">
    <view slot="right" class="nav-tag glass-icon">
      <image class="nav-icon" src="/styles/icon/AI.svg" mode="aspectFit" />
    </view>
  </navigation-bar>

  <scroll-view class="page-scroll" scroll-y="{{true}}" scroll-into-view="{{scrollToView}}" scroll-with-animation="{{true}}">
    <view class="page-content page-inner">
      <view class="welcome-panel glass-card" wx:if="{{chatMessages.length === 0}}">
        <text class="welcome-title">你好，我是智能美食推荐助手</text>
        <text class="welcome-desc">我可以根据口味、预算和场景给你推荐菜品。</text>

        <view class="quick-grid">
          <view class="quick-card motion-press" bind:tap="sendQuickQuestion" data-question="推荐几道川菜">
            <view class="quick-icon">🌶️</view>
            <view class="quick-text">
              <text class="quick-title">推荐川菜</text>
              <text class="quick-sub">麻辣鲜香</text>
            </view>
          </view>
          <view class="quick-card motion-press" bind:tap="sendQuickQuestion" data-question="推荐几道清淡的菜">
            <view class="quick-icon">🥗</view>
            <view class="quick-text">
              <text class="quick-title">清淡美食</text>
              <text class="quick-sub">低负担</text>
            </view>
          </view>
          <view class="quick-card motion-press" bind:tap="sendQuickQuestion" data-question="给我一个烹饪教程">
            <view class="quick-icon">👨‍🍳</view>
            <view class="quick-text">
              <text class="quick-title">烹饪教程</text>
              <text class="quick-sub">步骤清晰</text>
            </view>
          </view>
          <view class="quick-card motion-press" bind:tap="sendQuickQuestion" data-question="今天吃什么">
            <view class="quick-icon">🍽️</view>
            <view class="quick-text">
              <text class="quick-title">今天吃啥</text>
              <text class="quick-sub">快速决策</text>
            </view>
          </view>
        </view>
      </view>

      <view class="chat-list" wx:else>
        <view class="chat-row {{item.type}}" wx:for="{{chatMessages}}" wx:key="id" id="msg-{{item.id}}">
          <view class="message-avatar {{item.type}}">
            <image class="avatar-img" src="{{item.type === 'user' ? userAvatar : '/styles/icon/AI.svg'}}" mode="aspectFill" />
          </view>
          <view class="message-bubble {{item.type}}">
            <text class="message-text" user-select="{{true}}">{{item.content}}</text>
            <text class="message-time">{{item.time}}</text>
          </view>
        </view>

        <view class="loading-line" wx:if="{{isLoading}}">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
          <text class="loading-text">思考中...</text>
        </view>

        <view class="typing" wx:if="{{isTyping}}">
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="input-wrap">
    <view class="input-bar glass-card">
      <input class="message-input" placeholder="输入您的问题..." value="{{inputValue}}" bind:input="onInputChange" bind:confirm="sendMessage" confirm-type="send" adjust-position="{{true}}" />
      <button class="send-button {{inputValue ? 'active' : ''}}" bind:tap="sendMessage" disabled="{{!inputValue || isLoading}}">发送</button>
    </view>
  </view>
</view>
