/* pages/ranking/ranking.wxss */
.share-page {
  min-height: 100vh;
}

.page-scroll {
  height: 100vh;
}

.page-inner {
  padding: 190rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.nav-tag {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 30rpx;
  height: 30rpx;
}

/* 头像（入口条和帖子卡片共用） */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-soft);
  border: 1rpx solid var(--border-soft);
  flex-shrink: 0;
}

/* 发布入口条 */
.composer-entry {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.entry-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-soft);
  border: 1rpx solid var(--border-soft);
  flex-shrink: 0;
}

.entry-placeholder {
  flex: 1;
  font-size: var(--font-14);
  color: var(--text-muted);
}

.entry-btn {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, rgba(37,99,235,0.9), rgba(20,184,166,0.85));
  display: flex;
  align-items: center;
  justify-content: center;
}

.entry-btn-text {
  font-size: var(--font-14);
  font-weight: 600;
  color: #fff;
}

.feed-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: var(--font-24);
  line-height: var(--line-24);
  font-weight: 700;
  color: var(--text-primary);
}

.section-sub {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feed-card {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.feed-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feed-user {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.feed-name {
  font-size: var(--font-14);
  line-height: var(--line-14);
  font-weight: 600;
  color: var(--text-primary);
}

.feed-time {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.feed-content {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-secondary);
  word-break: break-all;
}

.comments-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: var(--bg-soft);
}

.comment-row {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.comment-name {
  font-size: var(--font-12);
  line-height: var(--line-12);
  font-weight: 600;
  color: var(--text-primary);
}

.comment-text {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-secondary);
  flex: 1;
}

.comment-time {
  font-size: var(--font-10);
  line-height: var(--line-10);
  color: var(--text-muted);
}

.feed-image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.feed-image {
  width: 100%;
  height: 180rpx;
  border-radius: 14rpx;
}

/* 视频显示 */
.feed-video-container {
  width: 100%;
  border-radius: 14rpx;
  overflow: hidden;
  background: #000;
}

.feed-video {
  width: 100%;
  height: 400rpx;
}

.feed-image:hover {
  transform: scale(1.03);
}

.comment-action-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comment-input-row {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 10rpx;
  border-radius: 12rpx;
  background: var(--bg-soft);
  border: 1rpx solid var(--border-soft);
}

.comment-input {
  flex: 1;
  height: 64rpx;
  padding: 0 12rpx;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-size: var(--font-14);
}

.comment-send {
  margin: 0;
  min-width: 82rpx;
  padding: 0 12rpx;
  height: 44rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.26) 0%, rgba(255, 255, 255, 0) 52%),
    linear-gradient(135deg, rgba(37, 99, 235, 0.92) 0%, rgba(37, 99, 235, 0.78) 100%);
  color: #f8fafc;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35),
    0 4rpx 12rpx rgba(37, 99, 235, 0.25);
}

.comment-send::after {
  border: none;
}

.comment-send:active {
  transform: translateY(2rpx);
}

.like-btn {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 48rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-soft);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.24) 0%, rgba(255, 255, 255, 0) 48%),
    rgba(255, 255, 255, 0.36);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
}

.like-icon {
  width: 24rpx;
  height: 24rpx;
}

.like-text {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.like-btn.liked .like-text {
  color: var(--color-danger);
}

.empty-state {
  padding: 24rpx;
  text-align: center;
}

.empty-text {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-muted);
}

@media (min-width: 960px) {
  .page-inner {
    width: 920rpx;
    margin: 0 auto;
  }
}
