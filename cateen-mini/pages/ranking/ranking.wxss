/* pages/ranking/ranking.wxss */
.ranking-container {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 176rpx; /* 导航栏高度 */
}

/* 榜单类型切换 */
.tab-bar {
  background: white;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 176rpx; /* 固定在导航栏下方 */
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #FF6B35;
  font-weight: bold;
  border-bottom-color: #FF6B35;
}

/* 筛选区域 */
.filter-section {
  background: white;
  padding: 20rpx 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.category-picker,
.time-picker {
  width: 100%;
}

.picker-display {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.picker-arrow {
  color: #999;
  font-size: 24rpx;
}

/* 排行榜列表 */
.ranking-list {
  padding: 20rpx 30rpx;
  flex: 1;
  overflow-y: auto;
  box-sizing: border-box;
}

.ranking-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 排名数字 */
.rank-number {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.rank-number.top-three {
  background: linear-gradient(135deg, #FFD700, #FF6B35);
}

.rank-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
}

.top-three .rank-text {
  color: white;
}

/* 美食图片 */
.food-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 15rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
  background-color: #f0f0f0;
  object-fit: cover;
}

/* 美食信息 */
.food-info {
  flex: 1;
  min-width: 0;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.food-category {
  font-size: 24rpx;
  color: #FF6B35;
  background: #FFF4F0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
  margin-bottom: 10rpx;
}

.rating-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.rating-text {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: bold;
  margin-left: 8rpx;
}

.rating-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.food-description {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 趋势指示 */
.rank-trend {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.trend-icon {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.trend-icon.up {
  color: #52c41a;
}

.trend-icon.down {
  color: #ff4d4f;
}

.trend-icon.same {
  color: #999;
}

.trend-value {
  font-size: 20rpx;
  color: #999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}