/* pages/lucky/lucky.wxss */
.lucky-container {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #ffd7b5 0%, #ffe8cb 42%, #fff3e5 72%, #f5ffe8 100%);
  min-height: 100vh;
  padding: 40rpx;
  padding-top: 216rpx;
}

.bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
  object-fit: cover;
  opacity: 0.75;
}

/* 婵犵绱曢崑鎴﹀磹濡ゅ懎鏋侀悹鍥ф▕閻掕棄霉閸忓吋缍戦柛鎰ㄥ亾闂備焦鎮堕崕娲礈閿曞倸姹?*/
.page-header {
  text-align: center;
  padding: 40rpx 30rpx;
  color: #1f2937;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 30rpx;
  color: #6b7280;
}

/* 闂傚倷鑳堕崢褔銆冩惔銏㈩洸婵犲﹤鐗婇崑鈺呮煟閹伴潧澧伴柍缁樻礀椤法鎹勯崫鍕靛妷缂備椒绶￠崳锝夊蓟閿濆鐓涢柛瀣仛閸ㄥ綊寮鈧畷濂稿即閻愭妲?*/
.custom-controls {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
}

.custom-btn {
  background: linear-gradient(135deg, #ff6b35 0%, #ff7f2a 100%);
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 44rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 12rpx 28rpx rgba(255, 107, 53, 0.3);
  width: 220rpx;
}

.custom-btn:active {
  background: #e55a2b;
  transform: scale(0.98);
}

/* 闂備礁鎼ˇ閬嶅磿閹版澘绀堟繛鎴炩棨妤﹁法鐤€婵炴垶顭囬ˇ閬嶆⒑閸涘﹦绠撻悗姘煎櫍瀹?*/
.wheel-section {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.wheel-container {
  position: relative;
  width: 600rpx;
  height: 600rpx;
}

/* 闂備礁鎼ˇ閬嶅磿閹版澘绀堟繛鎴炩棨妤﹁法鐤€婵炴垶鐟ュ▓鎴︽煟韫囨洖浠ч柛瀣崌閹?*/
.wheel-bg {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  position: relative;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.16);
  overflow: hidden;
  transition: transform 3s cubic-bezier(0.23, 1, 0.32, 1);
  border: 8rpx solid #ffffff;
}

/* 闂傚倷绀侀崥瀣偓绗涘懎鍨濈€光偓閸曨偆顔愰悷婊勬煥閻ｇ兘濡烽妷顔兼倯闂佹悶鍎卞Λ娑㈠磻閻斿摜顩?*/
.food-names-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 10;
  transition: transform 3s cubic-bezier(0.23, 1, 0.32, 1);
  will-change: transform;
}

.food-name-item {
  position: absolute;
  top: 50%;
  left: 50%;
  transform-origin: 0 0;
  width: 120rpx;
  height: 32rpx;
  margin-top: -16rpx;
  margin-left: -60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 缂傚倸鍊搁崐绋棵洪妶澶嬬厐闁挎繂锛嗘径鎰у璺猴龚琚濋柣搴＄畭閸庡崬鈻?*/
.food-name {
  font-size: 18rpx;
  color: #0f172a;
  text-align: center;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.7);
  line-height: 1.2;
  max-width: 120rpx;
  overflow: hidden;
  white-space: nowrap;
  transform: rotate(0deg); /* 闂備浇顕х换鎰崲閹邦儵娑橆煥閸剛绋忛梺鎸庢礀閸婂摜绮堥崘顔界厱婵炴垯鍩勯弳鎺旂磼椤旇姤宕岄柡灞糕偓鎰佸悑闁告侗鍘戒簺缂傚倷鐒﹂崬鑽ゆ閺囥垹绠熷ù鍏兼綑楠炪垺绻涢崱妯哄闁挎稒鍔栫换娑㈠箣閻愭潙纰嶉梺鍦拡閸嬪嫰顢氶敐鍡欘浄閻庯綆浜ｈ闂備胶鎳撻顓㈠磻閻愭牳澶屸偓锝庡枛缁?*/
}

/* 婵犵數鍋為崹鍫曞箹閳哄懎鍌ㄩ柤娴嬫櫇缁憋箑螖閿濆懎鏆欑紒鐘虫緲椤潡鎳滈棃娑橆潔闁?*/
.center-button {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b35 0%, #f97316 100%);
  border: 6rpx solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  box-shadow: 0 12rpx 32rpx rgba(249, 115, 22, 0.35);
  transition: all 0.3s ease;
}

.center-button:active {
  transform: translate(-50%, -50%) scale(0.95);
}

.button-text {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

/* 闂傚倷绀佸﹢閬嶁€﹂崼婢濇椽顢橀姀鐘殿唵?*/
.wheel-pointer {
  position: absolute;
  top: -40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 25rpx solid transparent;
  border-right: 25rpx solid transparent;
  border-bottom: 50rpx solid #ff6b35;
  z-index: 200;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.3));
}

.wheel-pointer::after {
  content: '';
  position: absolute;
  top: 50rpx;
  left: -20rpx;
  width: 0;
  height: 0;
  border-left: 20rpx solid transparent;
  border-right: 20rpx solid transparent;
  border-top: 20rpx solid #FF4757;
}

/* 缂傚倸鍊搁崐鐑芥倿閿曞倸绠板┑鐘崇閸婅泛顭跨捄渚叕闁搞倖娲熼弻娑㈡晜鐠囨彃绠婚悗?*/
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-modal.show {
  display: flex;
}

.result-content {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  margin: 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  max-width: 500rpx;
}

.result-header {
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.result-food {
  margin-bottom: 40rpx;
}

.result-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.result-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #FF4757;
  margin-bottom: 10rpx;
  display: block;
}

.result-category {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.result-rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.rating-text {
  font-size: 28rpx;
  color: #FF9500;
  font-weight: bold;
}

.result-description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 40rpx;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.result-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
}

.view-btn {
  background: #FF4757;
  color: #ffffff;
}

.view-btn:active {
  background: #FF3742;
  transform: scale(0.98);
}

.close-btn {
  background: #f5f5f5;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.close-btn:active {
  background: #e8e8e8;
  transform: scale(0.98);
}

/* 婵犵數鍋涢顓熸叏閹绢喗鏅濋柕澶堝剻濞戙垹鐓涢柛娑卞幘椤斿﹪姊洪棃娑辩劸闁告柨鐬肩划?*/
.recommendations-section {
  margin-top: 60rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.recommendations-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recommendation-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.recommendation-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.recommendation-info {
  flex: 1;
}

.recommendation-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.recommendation-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

.recommendation-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.rating-text {
  font-size: 24rpx;
  color: #FF9500;
}

/* 闂傚倷绀侀幉锟犳晪濠碘槅鍋呴〃澶愬Φ閹版澘绀堝ù锝囨嚀椤庢盯姊洪崫鍕垫Ъ婵炲娲滅划?*/
.history-section {
  margin-top: 60rpx;
  padding: 0 30rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-category {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 闂傚倷鑳堕崢褔銆冩惔銏㈩洸婵犲﹤鐗婇崑鈺呮煟閹伴潧澧伴柍缁樻礀椤法鎹勯崫鍕靛妷缂備椒绶￠崳锝夊蓟閿濆鐓涢柛瀣靛灱娴滎亪骞婂Ο鑽ょ瘈闁告洦鍘鹃獮?*/
.custom-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.custom-modal.show {
  display: flex;
}

.custom-content {
  background: #ffffff;
  border-radius: 20rpx;
  margin: 40rpx;
  max-width: 600rpx;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.custom-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.custom-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.custom-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

/* 闂備礁鎼ˇ顖炴偋婵犲洤绠伴柟闂寸閻鏌涢埄鍐槈缂佲偓瀹€鍕厱婵犻潧妫楅顐︽煕?*/
.input-section {
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.number-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}

.number-input:focus {
  border-color: #FF6B35;
}

/* 闂傚倷绀侀崥瀣偓绗涘懎鍨濈€光偓閸曨偆顔愰悷婊勬瀵宕ㄩ鑲╃獮闁诲函缍嗘禍鑸电閹绢喗鈷戦柛娑橈功婢ь亪鏌熺喊鍗炰喊闁?*/
.food-selector {
  padding: 30rpx;
}

.selector-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.food-list {
  max-height: 400rpx;
}

.food-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 10rpx;
  background: #f8f8f8;
  transition: all 0.3s ease;
}

.food-item.selected {
  background: #FFF4F0;
  border: 2rpx solid #FF6B35;
}

.food-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.food-category {
  font-size: 24rpx;
  color: #666;
}

.food-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
}

.food-check.checked {
  background: #FF6B35;
  border-color: #FF6B35;
}

/* 闂傚倷鑳堕幊鎾绘倶濠靛牏鐭撶€规洖娲ㄧ粈濠囨煛閸愩劎澧曠紒鐘虫緲椤潡鎳滈棃娑橆潔闁?*/
.custom-actions {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f0f0f0;
}

.custom-action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  transition: all 0.3s ease;
}

.cancel-btn {
  background: #f5f5f5;
  color: #333;
  border: 2rpx solid #e0e0e0;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.confirm-btn {
  background: #e0e0e0;
  color: #999;
}

.confirm-btn.active {
  background: #FF6B35;
  color: white;
}

.confirm-btn.active:active {
  background: #E55A2B;
}

/* 闂傚倷绀侀幉锛勬崲閸屾粎鐭撻悗鍨摃婵娊鏌熺紒妯轰刊闁搞倖娲熼悡顐﹀炊閵娿儱姣堥梺鍝ュ枎闁帮綁骞?*/
@media (max-width: 750rpx) {
  .wheel-container {
    width: 500rpx;
    height: 500rpx;
  }
  
  .food-name {
    font-size: 24rpx;
  }
  
  .center-button {
    width: 100rpx;
    height: 100rpx;
  }
  
  .button-text {
    font-size: 28rpx;
  }
  
  .custom-content {
    margin: 20rpx;
    max-height: 90vh;
  }
}
