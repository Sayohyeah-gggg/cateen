/* pages/index/index.wxss */
.index-page {
  min-height: 100vh;
}

.page-scroll {
  height: 100vh;
}

.page-inner {
  padding: 190rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.nav-tag {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 30rpx;
  height: 30rpx;
}

.search-section {
  padding: 20rpx;
}

.search-bar {
  height: 72rpx;
  border-radius: 32rpx;
  border: 1rpx solid var(--border-soft);
  background: var(--bg-surface-strong);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 20rpx;
}

.search-icon {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.75;
}

.search-input {
  flex: 1;
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-muted);
}

.section-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: var(--font-24);
  line-height: var(--line-24);
  font-weight: 700;
  color: var(--text-primary);
}

.section-sub {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-muted);
}

.popular-swiper {
  height: 320rpx;
  overflow: hidden;
}

.popular-card {
  position: relative;
  width: 100%;
  height: 100%;
}

.popular-image {
  width: 100%;
  height: 100%;
}

.popular-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx;
  background: linear-gradient(180deg, rgba(2, 6, 23, 0) 0%, rgba(2, 6, 23, 0.78) 100%);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.popular-name {
  color: #f8fafc;
  font-size: var(--font-20);
  line-height: var(--line-20);
  font-weight: 700;
}

.popular-meta {
  color: rgba(248, 250, 252, 0.88);
  font-size: var(--font-12);
  line-height: var(--line-12);
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 2rpx 2rpx 14rpx;
}

.category-item {
  min-width: 114rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  transition: transform var(--motion-fast) var(--ease-out);
}

.category-item:active {
  transform: scale(0.96);
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35),
    0 8rpx 18rpx rgba(2, 6, 23, 0.16);
  transition: transform var(--motion-fast) var(--ease-out), box-shadow var(--motion-fast) var(--ease-out), border-color var(--motion-fast) var(--ease-out);
}

.category-icon {
  width: 54rpx;
  height: 54rpx;
}

.category-name {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-primary);
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(2, 6, 23, 0.2);
}

.category-item.active .category-icon-wrap {
  border-color: rgba(255, 255, 255, 0.65);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.6),
    0 12rpx 24rpx rgba(2, 6, 23, 0.26);
  transform: translateY(-3rpx) scale(1.02);
}

.category-item.active .category-name {
  color: var(--text-primary);
  font-weight: 700;
}

.theme-dark .category-name,
.theme-dark .category-item.active .category-name {
  color: #f8fafc;
  text-shadow: 0 2rpx 4rpx rgba(2, 6, 23, 0.45);
}

.recommend-block {
  gap: 20rpx;
}

.food-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.loading-state {
  text-align: center;
  padding: 20rpx 0;
  font-size: var(--font-12);
  color: var(--text-secondary);
}

.loading-state.muted {
  color: var(--text-muted);
}

.empty-state {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-image {
  width: 220rpx;
  height: 160rpx;
  border-radius: 18rpx;
  opacity: 0.88;
}

.empty-text {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-muted);
}

@media (min-width: 960px) {
  .page-inner {
    width: 920rpx;
    margin: 0 auto;
  }

  .food-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}
