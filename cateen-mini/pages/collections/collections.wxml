<!-- pages/collections/collections.wxml -->
<view class="collections-container">
  <navigation-bar title="我的收藏" show-back="{{true}}" />

  <view class="collections-list">
    <view wx:if="{{loading && collections.length === 0}}" class="loading-container"><view class="loading-text">加载中...</view></view>

    <view wx:elif="{{collections.length === 0}}" class="empty-container">
      <image class="empty-image" src="/images/foods/gongbao-chicken.jpg" mode="aspectFit"></image>
      <view class="empty-text">还没有收藏</view>
      <view class="empty-desc">去首页挑几道喜欢的菜吧</view>
      <button class="discover-btn" bind:tap="goToIndex">去看看</button>
    </view>

    <view wx:else class="food-list">
      <view wx:for="{{collections}}" wx:key="id" class="food-item" bind:tap="goToDetail" data-id="{{item.food.id}}">
        <image class="food-image" src="{{item.food.images[0]}}" mode="aspectFill"></image>
        <view class="food-info">
          <view class="food-name">{{item.food.name}}</view>
          <view class="food-category">{{item.food.category}}</view>
          <view class="food-rating"><text class="rating-text">{{item.food.avgRating}}</text><text class="rating-star">*</text></view>
          <view class="food-price">￥{{item.food.price}}</view>
        </view>
        <view class="food-actions">
          <button class="remove-btn" bind:tap="removeCollection" data-food-id="{{item.food.id}}" data-collection-id="{{item.id}}" catch:tap="onNoop">取消收藏</button>
        </view>
      </view>
    </view>

    <view wx:if="{{collections.length > 0 && !noMore}}" class="load-more" bind:tap="loadMore"><text>加载更多</text></view>
    <view wx:if="{{noMore && collections.length > 0}}" class="no-more"><text>没有更多</text></view>
  </view>
</view>
