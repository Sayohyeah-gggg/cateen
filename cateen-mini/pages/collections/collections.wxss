/* pages/collections/collections.wxss */
.collections-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.collections-list {
  padding: 20rpx;
  margin-top: 176rpx; /* 导航栏高度 */
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 500rpx;
  text-align: center;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.discover-btn {
  background-color: #FF6B35;
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.food-item {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
}

.food-item:active {
  transform: scale(0.98);
}

.food-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.food-category {
  font-size: 24rpx;
  color: #999;
}

.food-rating {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.rating-text {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: bold;
}

.rating-star {
  font-size: 24rpx;
}

.food-price {
  font-size: 28rpx;
  color: #FF6B35;
  font-weight: bold;
}

.food-actions {
  margin-left: 20rpx;
}

.remove-btn {
  background-color: #f0f0f0;
  color: #666;
  border-radius: 30rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border: none;
}

.remove-btn:active {
  background-color: #e0e0e0;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx;
  color: #ccc;
  font-size: 26rpx;
}
