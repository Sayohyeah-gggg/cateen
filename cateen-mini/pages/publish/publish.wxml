<!-- pages/publish/publish.wxml -->
<view class="publish-page theme-shell {{themeClass}}">
  <navigation-bar title="发布分享" show-back="{{true}}" theme="{{theme}}" />

  <scroll-view class="page-scroll" scroll-y="{{true}}">
    <view class="page-inner">

      <!-- 用户信息 -->
      <view class="user-row">
        <image class="avatar" src="{{(userInfo && userInfo.avatarUrl) || '/images/default-avatar.jpg'}}" mode="aspectFill" />
        <view class="user-meta">
          <text class="user-name">{{(userInfo && userInfo.nickName) || '食客'}}</text>
          <text class="user-tip">分享你的美食故事</text>
        </view>
      </view>

      <!-- 文字输入 -->
      <textarea
        class="content-input"
        placeholder="想说点什么..."
        placeholder-class="input-placeholder"
        value="{{draftText}}"
        maxlength="300"
        bindinput="onDraftInput"
        auto-height="{{true}}"
      />

      <!-- 已选图片 -->
      <view class="image-grid" wx:if="{{selectedImages.length > 0}}">
        <view class="image-item" wx:for="{{selectedImages}}" wx:key="*this">
          <image class="preview-image" src="{{item}}" mode="aspectFill" bind:tap="previewImage" data-current="{{item}}" />
          <view class="remove-btn" bind:tap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="add-more" wx:if="{{selectedImages.length < 9}}" bind:tap="chooseImages">
          <text class="add-icon">+</text>
        </view>
      </view>

      <!-- 已选视频 -->
      <view class="video-container" wx:if="{{selectedVideo}}">
        <video class="preview-video" src="{{selectedVideo}}" bind:tap="previewVideo" />
        <view class="remove-video-btn" bind:tap="removeVideo">×</view>
      </view>

      <!-- 上传进度条 -->
      <view class="upload-progress-container" wx:if="{{showUploadProgress}}">
        <view class="progress-label">视频上传中 {{uploadProgress}}%</view>
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{uploadProgress}}%"></view>
        </view>
        <view class="progress-hint" wx:if="{{uploadProgress < 100}}">大视频上传中，请勿关闭页面</view>
        <view class="progress-hint" wx:else>上传完成，正在处理...</view>
      </view>

      <!-- 底部操作栏 -->
      <view class="action-bar">
        <view class="pick-btn motion-press" bind:tap="chooseImages" wx:if="{{selectedImages.length === 0 && !selectedVideo}}">
          <text class="pick-icon">🖼</text>
          <text class="pick-text">添加图片</text>
        </view>
        <view class="pick-btn motion-press" bind:tap="chooseVideo" wx:if="{{!selectedVideo && selectedImages.length === 0}}">
          <text class="pick-icon">🎥</text>
          <text class="pick-text">添加视频</text>
        </view>
        <view wx:else style="flex:1" />

        <button
          class="publish-btn {{canPublish ? 'enabled' : ''}}"
          bind:tap="publishPost"
          disabled="{{!canPublish || publishing}}"
        >{{publishing ? '发布中...' : '发布'}}</button>
      </view>

    </view>
  </scroll-view>
</view>
