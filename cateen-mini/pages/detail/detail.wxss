/* pages/detail/detail.wxss */
.detail-container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 闂傚倷鐒﹂幃鍫曞磿鏉堛劍娅犻柤鎭掑劜濞呯娀鏌″鍐ㄥ濠殿喗绮嶉妵鍕籍閸ヮ灝鎾绘倶韫囥儳绡€闁哄本鐩鍊燁槼闁诡垰鐗撻弻?*/
.image-section {
  position: relative;
}

.food-swiper {
  height: 400rpx;
}

.food-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 闂傚倷鑳剁涵鍫曞疾濠靛纾块柕鍫濇嫅閼板潡鏌ｅΔ鈧悧蹇涘煘瀹ュ鐓冮柍杞扮閺嗘洜绱掓潏銊у⒌闁哄本鐩鍊燁槼闁诡垰鐗撻弻?*/
.info-section {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.food-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.food-category {
  font-size: 28rpx;
  color: #FF6B35;
  background: #FFF4F0;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  display: inline-block;
  margin-bottom: 20rpx;
}

.rating-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.rating-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-left: 10rpx;
}

.rating-count {
  font-size: 28rpx;
  color: #999;
  margin-left: 10rpx;
}

.food-description {
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: #F0F0F0;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

/* 闂傚倷鑳堕幊鎾绘倶濠靛牏鐭撶€规洖娲ㄧ粈濠囨煛閸愩劎澧曠紒鐘虫緲椤潡鎳滈棃娑橆潔闁诲繐楠忕粻鎾诲蓟濞戙垹鍐€鐟滃酣骞嗛崼銉︾厽?*/
.action-section {
  background: white;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
}

.collect-btn {
  background: #FF6B35;
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  border: none;
}

.collect-btn.collected {
  background: #999;
}

/* 闂備浇宕垫慨鏉懨洪妶鍥ｅ亾濮樼厧鐏︽い銏＄懇楠炲鏁冮埀顒傜矆瀹€鍕厱婵犻潧妫楅顐︽煕?*/
.comment-section {
  background: white;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 闂備浇宕垫慨鏉懨洪妶鍥ｅ亾濮樼厧澧寸€规洝顫夐幆鏃堝閿涘嫮肖闂備浇顫夐崕鎶藉疮閸噮鍤曢柟鎯板Г閻撴洟鏌″畵顔煎閸庢捇姊?*/
.rating-input {
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.rating-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 20rpx;
}

.comment-input {
  width: 100%;
  min-height: 120rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 10rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  font-size: 28rpx;
  background: #fafafa;
}

.submit-btn {
  background: #FF6B35;
  color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  border: none;
  width: 200rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}

/* 闂備浇宕垫慨鏉懨洪妶鍥ｅ亾濮樼厧鐏︽い銏＄懇楠炲鏁冮埀顒傜矆閸℃ü绻嗛柕鍫濇噹椤忋儵鏌?*/
.comment-list {
  margin-top: 30rpx;
}

.comment-item {
  border-bottom: 2rpx solid #f0f0f0;
  padding: 30rpx 0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 5rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 30rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.comment-images {
  display: flex;
  gap: 10rpx;
  margin-bottom: 15rpx;
}

.comment-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.comment-actions {
  display: flex;
  justify-content: flex-end;
}

.like-btn {
  background: none;
  border: none;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
}

.like-btn.liked {
  color: #FF6B35;
  background: #FFF4F0;
}

.like-icon {
  margin-right: 8rpx;
}

/* 闂傚倷绀侀幉鈥愁潖缂佹ɑ鍙忛柟顖ｇ亹瑜版帒鐐婃い鎺嗗亾闁告濞婇弻鈩冨緞鐎ｎ亞鍔稿┑?*/
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}




