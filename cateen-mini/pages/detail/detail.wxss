/* pages/detail/detail.wxss */
.detail-page {
  min-height: 100vh;
}

.page-scroll {
  height: 100vh;
}

.page-inner {
  padding: 190rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 图片轮播 */
.swiper-wrap {
  overflow: hidden;
}

.food-swiper {
  height: 380rpx;
}

.food-image {
  width: 100%;
  height: 100%;
}

/* 基本信息卡片 */
.info-card {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 卡片底部行：收藏按钮右对齐 */
.info-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 8rpx;
  border-top: 1rpx solid var(--border-soft);
  margin-top: 4rpx;
}
.food-name {
  color: var(--text-primary);
}

.food-category-tag {
  display: inline-block;
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--color-accent);
  background: rgba(249, 115, 22, 0.12);
  border: 1rpx solid rgba(249, 115, 22, 0.25);
  padding: 6rpx 18rpx;
  border-radius: var(--radius-pill);
  align-self: flex-start;
}

.rating-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.rating-row .collect-btn {
  margin-left: auto;
}

.rating-score {
  font-size: var(--font-16);
  line-height: var(--line-16);
  font-weight: 700;
  color: var(--color-accent);
}

.rating-count {
  color: var(--text-muted);
}

.food-desc {
  color: var(--text-secondary);
  line-height: 1.6;
}

.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: var(--bg-soft);
  color: var(--text-muted);
  border: 1rpx solid var(--border-soft);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-pill);
}

/* 卡片底部行：收藏按钮右对齐 */
.info-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-soft);
  margin-top: 4rpx;
}

/* 收藏按钮 - 评分行右侧，小尺寸暖橙色 */
.collect-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  width: auto;
  min-width: 0;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--color-accent), #f59e0b);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  box-shadow: 0 2rpx 8rpx rgba(249, 115, 22, 0.35);
}

.collect-btn::after {
  border: none;
}

.collect-btn.collected {
  background: var(--bg-soft);
  color: var(--color-accent);
  border: 1rpx solid rgba(249, 115, 22, 0.35);
  box-shadow: none;
}

.collect-icon {
  font-size: 24rpx;
  line-height: 1;
}

/* 评论卡片 */
.comment-card {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: var(--text-primary);
}

/* 发表评论区 */
.rating-input-wrap {
  background: var(--bg-soft);
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-md);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rating-label {
  color: var(--text-secondary);
  font-weight: 600;
}

.comment-textarea {
  width: 100%;
  min-height: 120rpx;
  background: var(--bg-surface-strong);
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-sm);
  padding: 16rpx;
  font-size: var(--font-14);
  color: var(--text-primary);
  box-sizing: border-box;
}

.textarea-placeholder {
  color: var(--text-muted);
}

.submit-btn {
  align-self: flex-end;
  width: 160rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, var(--color-primary), #6366f1);
  color: #fff;
  font-size: var(--font-14);
  font-weight: 600;
  border: none;
  margin: 0;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: var(--bg-soft);
  color: var(--text-muted);
  border: 1rpx solid var(--border-soft);
}

/* 评论列表 */
.comment-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-soft);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.comment-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border-soft);
  flex-shrink: 0;
}

.user-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  color: var(--text-primary);
  font-weight: 600;
}

.comment-time {
  color: var(--text-muted);
}

.comment-content {
  color: var(--text-secondary);
  line-height: 1.6;
}

.comment-imgs {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.comment-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
}

.comment-footer {
  display: flex;
  justify-content: flex-end;
}

.like-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--bg-soft);
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-pill);
  padding: 8rpx 20rpx;
  color: var(--text-muted);
  font-size: var(--font-12);
  margin: 0;
  line-height: 1;
}

.like-btn::after {
  border: none;
}

.like-btn.liked {
  color: var(--color-accent);
  background: rgba(249, 115, 22, 0.1);
  border-color: rgba(249, 115, 22, 0.25);
}

.like-icon {
  font-size: var(--font-14);
}

.load-more {
  text-align: center;
  padding: 16rpx 0;
  color: var(--color-primary);
}

.empty-comments {
  text-align: center;
  padding: 24rpx 0;
  color: var(--text-muted);
}
