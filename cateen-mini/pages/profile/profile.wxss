/* pages/profile/profile.wxss */

.profile-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 用户信息区域 */
.user-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx 80rpx;
  margin-bottom: 20rpx;
  min-height: 200rpx;
}

/* 登录区域 */
.login-section {
  display: flex;
  align-items: center;
  gap: 30rpx;
  width: 100%;
}

.default-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.login-info {
  flex: 1;
}

.login-tip {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 20rpx;
}

.login-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50rpx;
  color: white;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  width: auto;
}

.login-btn::after {
  border: none;
}

/* 用户信息 */
.user-info {
  display: flex;
  align-items: flex-start;
  gap: 30rpx;
  width: 100%;
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-details {
  flex: 1;
  min-width: 0; /* 防止flex子元素溢出 */
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
  display: block;
}

.logout-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: white;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.user-stats {
  display: flex;
  gap: 40rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 功能菜单 */
.menu-section {
  background: white;
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.2s ease;
}

.menu-item:active {
  background: #f8f8f8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.featured {
  background: linear-gradient(135deg, #FFF4F0 0%, #FFE8E0 100%);
  border-bottom: 2rpx solid #FFD0C0;
}

.menu-item.featured .menu-icon {
  font-size: 48rpx;
  animation: rotate 3s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-title {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.menu-item.featured .menu-title {
  font-weight: bold;
  color: #FF6B35;
}

.menu-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.menu-count {
  font-size: 28rpx;
  color: #999;
}

.menu-desc {
  font-size: 26rpx;
  color: #FF6B35;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 最近收藏/评论区域 */
.recent-section {
  background: white;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 28rpx;
  color: #666;
}

/* 最近收藏列表 */
.recent-list {
  white-space: nowrap;
  padding: 20rpx 0;
}

.recent-item {
  display: inline-block;
  width: 200rpx;
  margin-left: 30rpx;
  text-align: center;
}

.recent-image {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.recent-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.rating-text {
  font-size: 24rpx;
  color: #ff6b35;
  font-weight: bold;
}

/* 评论列表 */
.comment-list {
  padding: 0 30rpx;
}

.comment-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-food-image {
  width: 100rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.comment-info {
  flex: 1;
}

.comment-food-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.comment-rating {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

/* 其他功能区域 */
.other-section {
  background: white;
  margin-bottom: 20rpx;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80%;
  overflow: hidden;
  transform: scale(0.8);
  transition: transform 0.3s ease;
}

.modal.show .modal-content {
  transform: scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  text-align: center;
}

.app-version {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
  text-align: center;
}

.app-description {
  font-size: 30rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.contact-info {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}