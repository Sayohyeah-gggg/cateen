/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
}

.page-scroll {
  height: 100vh;
}

.page-inner {
  padding: 190rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.nav-tag {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  width: 30rpx;
  height: 30rpx;
}

.user-card {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.user-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border-soft);
  background: var(--bg-soft);
}

.name-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.name {
  font-size: var(--font-20);
  line-height: var(--line-20);
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.login-btn,
.logout-btn {
  margin: 0;
  width: 108rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--border-soft);
  background: var(--bg-glass-strong);
  color: var(--text-secondary);
  font-size: var(--font-12);
  font-weight: 600;
  padding: 0;
}

.login-btn::after,
.logout-btn::after {
  border: none;
}

.stats-row {
  display: flex;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  padding: 14rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--border-soft);
  background: var(--bg-surface-strong);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: var(--font-20);
  line-height: var(--line-20);
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.theme-card,
.menu-card {
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
}

.section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: var(--font-20);
  line-height: var(--line-20);
  color: var(--text-primary);
  font-weight: 700;
}

.section-sub {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.theme-switch {
  display: flex;
  gap: 12rpx;
}

.theme-btn {
  flex: 1;
  height: 64rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--border-soft);
  background: var(--bg-surface-strong);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-14);
  color: var(--text-secondary);
  transition: all var(--motion-fast) var(--ease-out);
}

.theme-btn.active {
  color: var(--text-inverse);
  border-color: transparent;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 70rpx;
  border-bottom: 1rpx solid var(--border-soft);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 30rpx;
  height: 30rpx;
}

.menu-title {
  flex: 1;
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-secondary);
}

.menu-extra {
  font-size: var(--font-12);
  line-height: var(--line-12);
  color: var(--text-muted);
}

.menu-arrow {
  color: var(--text-muted);
  font-size: var(--font-14);
}

.modal {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity var(--motion-fast) var(--ease-out);
}

.modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-content {
  width: 620rpx;
  max-width: calc(100vw - 48rpx);
  padding: 20rpx;
}

.modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: var(--font-20);
  line-height: var(--line-20);
  color: var(--text-primary);
  font-weight: 700;
}

.modal-close {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  border: 1rpx solid var(--border-soft);
  text-align: center;
  line-height: 44rpx;
  color: var(--text-muted);
}

.modal-body {
  margin-top: 14rpx;
}

.about-text {
  font-size: var(--font-14);
  line-height: var(--line-14);
  color: var(--text-secondary);
}

@media (min-width: 960px) {
  .page-inner {
    width: 920rpx;
    margin: 0 auto;
  }
}
