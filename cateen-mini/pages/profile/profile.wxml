<!--个人中心页面-->
<page-meta>
  <navigation-bar title="个人中心" />
</page-meta>
<view class="profile-container">
  
  <!-- 用户信息区域 -->
  <view class="user-section">
    <!-- 未登录状态 -->
    <view class="login-section" wx:if="{{!isLoggedIn}}">
      <image class="default-avatar" src="/images/default-avatar.jpg" />
      <view class="login-info">
        <text class="login-tip">登录后享受更多功能</text>
        <button class="login-btn" bind:tap="onWechatLogin">
          微信授权登录
        </button>
      </view>
    </view>
    
    <!-- 已登录状态 -->
    <view class="user-info" wx:else>
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.jpg'}}" />
      <view class="user-details">
        <text class="user-name">{{userInfo.nickName || '美食爱好者'}}</text>
        <view class="user-stats">
          <view class="stat-item">
            <text class="stat-number">{{userInfo.collectCount || 0}}</text>
            <text class="stat-label">收藏</text>
          </view>
          <view class="stat-item">
            <text class="stat-number">{{userInfo.commentCount || 0}}</text>
            <text class="stat-label">评论</text>
          </view>
        </view>
      </view>
      <view class="logout-btn" bind:tap="onLogout">退出</view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <!-- 幸运转盘 -->
    <view class="menu-item featured" bind:tap="goToLucky">
      <view class="menu-icon">🎯</view>
      <text class="menu-title">幸运转盘</text>
      <view class="menu-info">
        <text class="menu-desc">今天吃什么？</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 我的收藏 -->
    <view class="menu-item" bind:tap="goToCollections">
      <view class="menu-icon">❤️</view>
      <text class="menu-title">我的收藏</text>
      <view class="menu-info">
        <text class="menu-count">{{userInfo.collectCount || 0}}个</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <!-- 我的评论 -->
    <view class="menu-item" bind:tap="goToComments">
      <view class="menu-icon">💬</view>
      <text class="menu-title">我的评论</text>
      <view class="menu-info">
        <text class="menu-count">{{userInfo.commentCount || 0}}条</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 最近收藏 -->
  <view class="recent-section" wx:if="{{recentCollections.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近收藏</text>
      <text class="section-more" bind:tap="goToCollections">查看全部</text>
    </view>
    <scroll-view class="recent-list" scroll-x="{{true}}">
      <view class="recent-item" wx:for="{{recentCollections}}" wx:key="id" bind:tap="goToDetail" data-id="{{item.food.id}}">
        <image class="recent-image" src="{{item.food.images[0]}}" mode="aspectFill" />
        <text class="recent-name">{{item.food.name}}</text>
        <view class="recent-rating">
          <rating-star rating="{{item.food.avgRating || 0}}" size="mini" />
          <text class="rating-text">{{item.food.avgRating}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 最近评论 -->
  <view class="recent-section" wx:if="{{recentComments.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近评论</text>
      <text class="section-more" bind:tap="goToComments">查看全部</text>
    </view>
    <view class="comment-list">
      <view class="comment-item" wx:for="{{recentComments}}" wx:key="id" bind:tap="goToDetail" data-id="{{item.food.id}}">
        <image class="comment-food-image" src="{{item.food.images[0]}}" mode="aspectFill" />
        <view class="comment-info">
          <text class="comment-food-name">{{item.food.name}}</text>
          <view class="comment-rating">
            <rating-star rating="{{item.rating || 0}}" size="mini" />
            <text class="comment-time">{{item.createTime}}</text>
          </view>
          <text class="comment-content">{{item.content}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 其他功能 -->
  <view class="other-section">
    <view class="menu-item" bind:tap="showAbout">
      <view class="menu-icon">ℹ️</view>
      <text class="menu-title">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bind:tap="showAgreement">
      <view class="menu-icon">📄</view>
      <text class="menu-title">用户协议</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bind:tap="showPrivacy">
      <view class="menu-icon">🔒</view>
      <text class="menu-title">隐私政策</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>

<!-- 关于我们弹窗 -->
<view class="modal {{showAboutModal ? 'show' : ''}}" bind:tap="hideModal">
  <view class="modal-content" catch:tap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">关于我们</text>
      <text class="modal-close" bind:tap="hideModal">×</text>
    </view>
    <view class="modal-body">
      <text class="app-name">美食展示评分小程序</text>
      <text class="app-version">版本 1.0.0</text>
      <text class="app-description">
        一个专注于美食展示、评分和互动的微信小程序。
        我们致力于为用户提供最优质的美食推荐和交流平台，
        让每一次用餐都成为美好的体验。
      </text>
      <text class="contact-info">联系我们：cateen@example.com</text>
    </view>
  </view>
</view>