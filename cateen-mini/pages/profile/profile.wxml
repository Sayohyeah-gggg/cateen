<!-- pages/profile/profile.wxml -->
<view class="profile-page theme-shell {{themeClass}}">
  <navigation-bar title="我的" theme="{{theme}}">
    <view slot="right" class="nav-tag glass-icon"><image class="nav-icon" src="/styles/icon/myHome.svg" mode="aspectFit" /></view>
  </navigation-bar>

  <scroll-view class="page-scroll" scroll-y="{{true}}">
    <view class="page-content page-inner">
      <view class="user-card glass-card">
        <view class="user-head">
          <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.jpg'}}" mode="aspectFill" />
          <view class="name-wrap"><text class="name">{{userInfo.nickName || '游客'}}</text><text class="sub">食堂优选</text></view>
          <button class="login-btn" wx:if="{{!isLoggedIn}}" bind:tap="onWechatLogin">登录</button>
          <button class="logout-btn" wx:else bind:tap="onLogout">退出登录</button>
        </view>

        <view class="stats-row">
          <view class="stat-item"><text class="stat-num">{{userInfo.collectCount || 0}}</text><text class="stat-label">收藏</text></view>
          <view class="stat-item"><text class="stat-num">{{userInfo.commentCount || 0}}</text><text class="stat-label">评论</text></view>
        </view>
      </view>

      <view class="theme-card glass-card">
        <view class="section-row"><text class="section-title">主题</text><text class="section-sub">明 / 暗</text></view>
        <view class="theme-switch">
          <view class="theme-btn {{currentTheme === 'light' ? 'active' : ''}}" data-theme="light" bind:tap="switchTheme">明亮</view>
          <view class="theme-btn {{currentTheme === 'dark' ? 'active' : ''}}" data-theme="dark" bind:tap="switchTheme">深色</view>
        </view>
      </view>

      <view class="menu-card glass-card">
        <view class="menu-item" bind:tap="goToLucky"><text class="menu-title">幸运转盘</text><text class="menu-arrow">></text></view>
        <view class="menu-item" bind:tap="goToCollections"><text class="menu-title">我的收藏</text><text class="menu-extra">{{userInfo.collectCount || 0}}</text><text class="menu-arrow">></text></view>
        <view class="menu-item" bind:tap="goToComments"><text class="menu-title">我的评论</text><text class="menu-extra">{{userInfo.commentCount || 0}}</text><text class="menu-arrow">></text></view>
      </view>

      <view class="menu-card glass-card">
        <view class="menu-item" bind:tap="showAbout"><text class="menu-title">关于</text><text class="menu-arrow">></text></view>
        <view class="menu-item" bind:tap="showAgreement"><text class="menu-title">用户协议</text><text class="menu-arrow">></text></view>
        <view class="menu-item" bind:tap="showPrivacy"><text class="menu-title">隐私政策</text><text class="menu-arrow">></text></view>
      </view>
    </view>
  </scroll-view>

  <view class="modal {{showAboutModal ? 'show' : ''}}" bind:tap="hideModal">
    <view class="modal-content glass-card" catch:tap="stopPropagation">
      <view class="modal-head"><text class="modal-title">关于</text><text class="modal-close" bind:tap="hideModal">x</text></view>
      <view class="modal-body"><text class="about-text">食堂优选是一款食堂菜品浏览与分享的小程序。</text></view>
    </view>
  </view>
</view>
