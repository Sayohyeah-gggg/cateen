<!-- pages/comments/comments.wxml -->
<view class="comments-container">
  <navigation-bar title="我的评论" show-back="{{true}}" />

  <view class="comments-list">
    <view wx:if="{{loading && comments.length === 0}}" class="loading-container"><view class="loading-text">加载中...</view></view>

    <view wx:elif="{{comments.length === 0}}" class="empty-container">
      <image class="empty-image" src="/images/foods/gongbao-chicken.jpg" mode="aspectFit"></image>
      <view class="empty-text">暂时还没有评论</view>
      <view class="empty-desc">去菜品详情写下第一条评论吧</view>
      <button class="discover-btn" bind:tap="goToIndex">去逛逛</button>
    </view>

    <view wx:else class="comment-list">
      <view wx:for="{{comments}}" wx:for-item="comment" wx:key="id" class="comment-item">
        <view class="food-info" bind:tap="goToDetail" data-id="{{comment.foodId}}">
          <image class="food-image" src="{{comment.foodImage}}" mode="aspectFill"></image>
          <view class="food-details"><view class="food-name">{{comment.foodName}}</view><view class="comment-time">{{comment.createdAt}}</view></view>
        </view>

        <view class="rating-section">
          <view class="rating-stars">
            <text wx:for="{{[1,2,3,4,5]}}" wx:for-item="score" wx:key="*this" class="star {{score <= comment.rating ? 'active' : ''}}">*</text>
          </view>
          <text class="rating-text">{{comment.rating}}</text>
        </view>

        <view class="comment-content">{{comment.content}}</view>

        <view wx:if="{{comment.images && comment.images.length}}" class="comment-images">
          <image wx:for="{{comment.images}}" wx:key="*this" wx:for-item="image" class="comment-image" src="{{image}}" mode="aspectFill" bind:tap="previewImage" data-current="{{image}}" data-urls="{{comment.images}}"></image>
        </view>

        <view class="comment-actions">
          <button class="action-btn like-btn {{comment.isLiked ? 'liked' : ''}}" bind:tap="likeComment" data-comment-id="{{comment.id}}" data-is-liked="{{comment.isLiked}}"><text class="btn-icon">L</text><text class="btn-text">{{comment.likeCount}}</text></button>
          <button class="action-btn delete-btn" bind:tap="deleteComment" data-comment-id="{{comment.id}}"><text class="btn-icon">删</text><text class="btn-text">删除</text></button>
        </view>
      </view>
    </view>

    <view wx:if="{{comments.length > 0 && !noMore}}" class="load-more" bind:tap="loadMore"><text>加载更多</text></view>
    <view wx:if="{{noMore && comments.length > 0}}" class="no-more"><text>没有更多</text></view>
  </view>
</view>
