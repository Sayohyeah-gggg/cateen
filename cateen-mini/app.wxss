@import '/styles/common.wxss';

page {
  /* 8pt Grid */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 48rpx;
  --space-6: 64rpx;
  --space-7: 80rpx;
  --space-8: 96rpx;

  /* Radius */
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;

  /* Typography */
  --font-32: 64rpx;
  --font-24: 48rpx;
  --font-20: 40rpx;
  --font-16: 32rpx;
  --font-14: 28rpx;
  --font-12: 24rpx;

  --line-32: 1.2;
  --line-24: 1.3;
  --line-20: 1.35;
  --line-16: 1.45;
  --line-14: 1.5;
  --line-12: 1.6;

  /* Motion */
  --motion-fast: 180ms;
  --motion-mid: 260ms;
  --ease-out: cubic-bezier(0.2, 0.8, 0.2, 1);

  /* Light Tokens */
  --bg-page: #edf2f9;
  --bg-surface: rgba(255, 255, 255, 0.72);
  --bg-surface-strong: rgba(255, 255, 255, 0.92);
  --bg-soft: rgba(247, 250, 255, 0.85);
  --bg-glass: rgba(255, 255, 255, 0.2);
  --bg-glass-strong: rgba(255, 255, 255, 0.36);

  --text-primary: #0f172a;
  --text-secondary: #334155;
  --text-muted: #64748b;
  --text-inverse: #f8fafc;

  --color-primary: #2563eb;
  --color-secondary: #14b8a6;
  --color-accent: #f97316;
  --color-danger: #ef4444;

  --border-soft: rgba(148, 163, 184, 0.25);
  --border-strong: rgba(148, 163, 184, 0.42);

  --shadow-sm: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
  --shadow-md: 0 14rpx 40rpx rgba(15, 23, 42, 0.1);

  min-height: 100%;
  background: var(--bg-page);
  color: var(--text-primary);
  font-family: 'PingFang SC', 'SF Pro Display', 'Helvetica Neue', sans-serif;
}

.theme-light {
  --bg-page: #edf2f9;
  --bg-surface: rgba(255, 255, 255, 0.72);
  --bg-surface-strong: rgba(255, 255, 255, 0.92);
  --bg-soft: rgba(247, 250, 255, 0.85);
  --bg-glass: rgba(255, 255, 255, 0.2);
  --bg-glass-strong: rgba(255, 255, 255, 0.36);

  --text-primary: #0f172a;
  --text-secondary: #334155;
  --text-muted: #64748b;
  --text-inverse: #f8fafc;

  --color-primary: #2563eb;
  --color-secondary: #14b8a6;
  --color-accent: #f97316;
  --color-danger: #ef4444;

  --border-soft: rgba(148, 163, 184, 0.25);
  --border-strong: rgba(148, 163, 184, 0.42);

  --shadow-sm: 0 8rpx 20rpx rgba(15, 23, 42, 0.06);
  --shadow-md: 0 14rpx 40rpx rgba(15, 23, 42, 0.1);
}

.theme-dark {
  --bg-page: #0b1220;
  --bg-surface: rgba(15, 23, 42, 0.6);
  --bg-surface-strong: rgba(15, 23, 42, 0.86);
  --bg-soft: rgba(30, 41, 59, 0.72);
  --bg-glass: rgba(148, 163, 184, 0.16);
  --bg-glass-strong: rgba(148, 163, 184, 0.24);

  --text-primary: #e2e8f0;
  --text-secondary: #cbd5e1;
  --text-muted: #94a3b8;
  --text-inverse: #020617;

  --color-primary: #60a5fa;
  --color-secondary: #2dd4bf;
  --color-accent: #fb923c;
  --color-danger: #f87171;

  --border-soft: rgba(148, 163, 184, 0.3);
  --border-strong: rgba(148, 163, 184, 0.46);

  --shadow-sm: 0 10rpx 24rpx rgba(2, 6, 23, 0.35);
  --shadow-md: 0 18rpx 50rpx rgba(2, 6, 23, 0.5);
}

.theme-shell {
  position: relative;
  min-height: 100vh;
  color: var(--text-primary);
  background: var(--bg-page);
}

.theme-shell::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 10% 0%, rgba(249, 115, 22, 0.2), transparent 40%),
    radial-gradient(circle at 88% 16%, rgba(37, 99, 235, 0.22), transparent 42%),
    linear-gradient(140deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0) 55%);
  z-index: 0;
}

.page-content {
  position: relative;
  z-index: 1;
}

.glass-card {
  background: var(--bg-surface);
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.glass-icon {
  background: var(--bg-glass-strong);
  border: 1rpx solid var(--border-soft);
  border-radius: var(--radius-md);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.title-32 {
  font-size: var(--font-32);
  line-height: var(--line-32);
  font-weight: 700;
}

.title-24 {
  font-size: var(--font-24);
  line-height: var(--line-24);
  font-weight: 700;
}

.title-20 {
  font-size: var(--font-20);
  line-height: var(--line-20);
  font-weight: 600;
}

.text-16 {
  font-size: var(--font-16);
  line-height: var(--line-16);
}

.text-14 {
  font-size: var(--font-14);
  line-height: var(--line-14);
}

.text-12 {
  font-size: var(--font-12);
  line-height: var(--line-12);
}

.motion-press {
  transition: transform var(--motion-fast) var(--ease-out), box-shadow var(--motion-fast) var(--ease-out);
}

.motion-press:active {
  transform: scale(0.97);
}

.hairline {
  border: 1rpx solid var(--border-soft);
}
