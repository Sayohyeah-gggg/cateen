<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xawl.cateen.mapper.CommentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xawl.cateen.entity.Comment">
        <id column="id" property="id"/>
        <result column="food_id" property="foodId"/>
        <result column="user_id" property="userId"/>
        <result column="content" property="content"/>
        <result column="rating" property="rating"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- CommentVO结果映射 -->
    <resultMap id="CommentVOResultMap" type="com.xawl.cateen.vo.CommentVO">
        <id column="id" property="id"/>
        <result column="food_id" property="foodId"/>
        <result column="food_name" property="foodName"/>
        <result column="user_id" property="userId"/>
        <result column="user_phone" property="userPhone"/>
        <result column="user_nickname" property="userNickname"/>
        <result column="user_avatar" property="userAvatar"/>
        <result column="content" property="content"/>
        <result column="rating" property="rating"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 分页查询评论列表 -->
    <select id="selectCommentPage" resultMap="CommentVOResultMap">
        SELECT
            c.id,
            c.food_id,
            f.name AS food_name,
            c.user_id,
            p.phone AS user_phone,
            p.nickname AS user_nickname,
            p.avatar AS user_avatar,
            c.content,
            c.rating,
            c.status,
            c.created_at
        FROM comments c
        LEFT JOIN foods f ON c.food_id = f.id
        LEFT JOIN profiles p ON c.user_id = p.id
        <where>
            <if test="keyword != null and keyword != ''">
                AND c.content LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="foodId != null and foodId != ''">
                AND c.food_id = #{foodId}
            </if>
            <if test="userId != null and userId != ''">
                AND c.user_id = #{userId}
            </if>
            <if test="status != null and status != ''">
                AND c.status = #{status}
            </if>
            <if test="rating != null">
                AND c.rating = #{rating}
            </if>
        </where>
        ORDER BY c.created_at DESC
    </select>

    <!-- 查询评论详情 -->
    <select id="selectCommentDetailById" resultMap="CommentVOResultMap">
        SELECT
            c.id,
            c.food_id,
            f.name AS food_name,
            c.user_id,
            p.phone AS user_phone,
            p.nickname AS user_nickname,
            p.avatar AS user_avatar,
            c.content,
            c.rating,
            c.status,
            c.created_at
        FROM comments c
        LEFT JOIN foods f ON c.food_id = f.id
        LEFT JOIN profiles p ON c.user_id = p.id
        WHERE c.id = #{id}
    </select>

</mapper>

