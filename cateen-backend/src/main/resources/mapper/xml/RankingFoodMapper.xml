<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xawl.cateen.mapper.RankingFoodMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xawl.cateen.entity.RankingFood">
        <id column="id" property="id"/>
        <result column="ranking_id" property="rankingId"/>
        <result column="food_id" property="foodId"/>
        <result column="rank_position" property="rankPosition"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 批量插入榜单美食关联 -->
    <insert id="batchInsert">
        INSERT INTO ranking_foods (id, ranking_id, food_id, rank_position, created_at)
        VALUES
        <foreach collection="relations" item="item" separator=",">
            (#{item.id}, #{item.rankingId}, #{item.foodId}, #{item.rankPosition}, #{item.createdAt})
        </foreach>
    </insert>

    <!-- 删除榜单的所有美食关联 -->
    <delete id="deleteByRankingId">
        DELETE FROM ranking_foods
        WHERE ranking_id = #{rankingId}
    </delete>

</mapper>

