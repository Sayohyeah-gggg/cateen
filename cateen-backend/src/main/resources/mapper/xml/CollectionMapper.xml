<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xawl.cateen.mapper.CollectionMapper">

    <!-- 统计用户收藏数 -->
    <select id="countByUserId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM collection
        WHERE user_id = #{userId}
    </select>

    <!-- 统计美食收藏数 -->
    <select id="countByFoodId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM collection
        WHERE food_id = #{foodId}
    </select>

    <!-- 检查是否已收藏 -->
    <select id="existsByUserIdAndFoodId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM collection
        WHERE user_id = #{userId} AND food_id = #{foodId}
    </select>

</mapper>
