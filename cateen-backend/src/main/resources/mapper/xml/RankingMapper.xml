<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xawl.cateen.mapper.RankingMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xawl.cateen.entity.Ranking">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="type" property="type"/>
        <result column="status" property="status"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- RankingVO结果映射 -->
    <resultMap id="RankingVOResultMap" type="com.xawl.cateen.vo.RankingVO">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="type" property="type"/>
        <result column="status" property="status"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <collection property="foods" ofType="com.xawl.cateen.vo.RankingVO$RankingFoodVO">
            <id column="rf_id" property="id"/>
            <result column="rank_position" property="rankPosition"/>
            <association property="food" javaType="com.xawl.cateen.vo.FoodVO">
                <id column="food_id" property="id"/>
                <result column="food_name" property="name"/>
                <result column="food_rating" property="rating"/>
                <result column="food_image_url" property="imageUrl"/>
            </association>
        </collection>
    </resultMap>

    <!-- 分页查询榜单列表 -->
    <select id="selectRankingPage" resultMap="RankingVOResultMap">
        SELECT
            r.id,
            r.title,
            r.description,
            r.type,
            r.status,
            r.created_by,
            r.created_at,
            r.updated_at,
            rf.id AS rf_id,
            rf.rank_position,
            f.id AS food_id,
            f.name AS food_name,
            f.rating AS food_rating,
            f.image_url AS food_image_url
        FROM rankings r
        LEFT JOIN ranking_foods rf ON r.id = rf.ranking_id
        LEFT JOIN foods f ON rf.food_id = f.id
        <where>
            <if test="keyword != null and keyword != ''">
                AND r.title LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="type != null and type != ''">
                AND r.type = #{type}
            </if>
            <if test="status != null and status != ''">
                AND r.status = #{status}
            </if>
        </where>
        ORDER BY r.created_at DESC, rf.rank_position ASC
    </select>

    <!-- 查询榜单详情 -->
    <select id="selectRankingDetailById" resultMap="RankingVOResultMap">
        SELECT
            r.id,
            r.title,
            r.description,
            r.type,
            r.status,
            r.created_by,
            r.created_at,
            r.updated_at,
            rf.id AS rf_id,
            rf.rank_position,
            f.id AS food_id,
            f.name AS food_name,
            f.description AS food_description,
            f.rating AS food_rating,
            f.rating_count AS food_rating_count,
            f.price AS food_price,
            f.image_url AS food_image_url
        FROM rankings r
        LEFT JOIN ranking_foods rf ON r.id = rf.ranking_id
        LEFT JOIN foods f ON rf.food_id = f.id
        WHERE r.id = #{id}
        ORDER BY rf.rank_position ASC
    </select>

</mapper>

